# dbt Cloud Importer Configuration
# Copy this file to .env and fill in your actual credentials

# Source account (for fetch command)
DBT_SOURCE_HOST=https://cloud.getdbt.com
DBT_SOURCE_ACCOUNT_ID=<your_source_account_id>
DBT_SOURCE_API_TOKEN=<your_source_api_token>

# Optional: API client configuration
# DBT_SOURCE_API_TIMEOUT=30
# DBT_SOURCE_API_MAX_RETRIES=5
# DBT_SOURCE_API_BACKOFF_FACTOR=1.5
# DBT_SOURCE_API_RETRY_AFTER=true
# DBT_SOURCE_SSL_VERIFY=true
# DBT_REPORT_LINE_ITEM_START=1001

# Target account (for Terraform apply)
# These are used as Terraform variables when running terraform apply
# TF_VAR_dbt_account_id=<target_account_id>
# TF_VAR_dbt_token=<target_api_token>
# TF_VAR_dbt_pat=<target_pat>
# TF_VAR_token_map='{"token_name": "token_value"}'
